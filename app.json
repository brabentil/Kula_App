{
  "expo": {
    "name": "Kula",
    "slug": "kula",
    "scheme": "kula",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/kula-loading-mark-dark.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/kula-loading-mark-dark.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF3E0"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/kula-adaptive-foreground.png",
        "backgroundColor": "#1D9E75"
      },
      "package": "com.anonymous.social"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}
